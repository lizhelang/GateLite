PORT=3001
TRAEFIK_API_URL=http://localhost:18081
GATELITE_STATE_FILE=runtime/gatelite-state.json
GATELITE_DYNAMIC_FILE=runtime/traefik/gatelite.yml
GATELITE_CERT_DIR=runtime/certs
GATELITE_CERT_MOUNT_PATH=/certs
GATELITE_SEED_DEMO=true
GATELITE_IMAGE=ghcr.io/lizhelang/gatelite:latest

# Optional read-only ACME observability inputs. These let GateLite display
# Traefik resolver and acme.json state without storing DNS provider secrets.
GATELITE_TRAEFIK_STATIC_CONFIG_FILE=
GATELITE_ACME_STORAGE_FILE=

# Example public deployment host used by the Portainer stack template.
# Replace this with the hostname that points to your own Traefik ingress.
GATELITE_HOST=gatelite.example.com
GATELITE_PUBLIC_URLS=https://gatelite.example.com

# Optional access control. Default is off.
GATELITE_AUTH_ENABLED=false
GATELITE_AUTH_USERNAME=
GATELITE_AUTH_PASSWORD=
GATELITE_VIEWER_TOKEN=
GATELITE_AGENT_TOKEN=
GATELITE_OPERATOR_TOKEN=
GATELITE_ADMIN_TOKEN=
# Optional compact token list: viewer:<token>,agent:<token>,operator:<token>,admin:<token>
GATELITE_AUTH_TOKENS=

# Optional Cloudflare DNS/DDNS management. This requires
# GATELITE_AUTH_ENABLED=true when enabled.
GATELITE_DNS_ENABLED=false
GATELITE_DNS_INTERVAL_SECONDS=300
GATELITE_DNS_TARGET_IPV4=
GATELITE_DNS_PUBLIC_IPV4_URLS=https://ifconfig.co/ip,https://api.ipify.org
# zone=token pairs separated by semicolons. Tokens are never returned by API/UI.
GATELITE_CLOUDFLARE_ZONE_TOKENS=example.com=<cloudflare-token>
# zone|type|name|content|proxied|ttl|comment; use @ipv4 for the discovered IPv4.
GATELITE_DNS_RECORDS=example.com|A|example.com|@ipv4|true|1|Managed by GateLite;example.com|A|*.example.com|@ipv4|true|1|Managed by GateLite
